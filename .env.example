CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=
CAPITAL_API_KEY_PASSWORD=

MONITOR_INTERVAL_SECONDS=60
LOG_LEVEL=INFO

# Paths — defaults are set as ENV in Containerfile; only override if running outside the container
# CONFIG_DIR=./config
# DB_PATH=./data/trading.db
# AUDIT_LOG_PATH=./data/audit.jsonl

# Backtesting — path to the SQLite DB populated by backtest/fetch_ohlc.py (Windows-side script)
# BACKTEST_DB_PATH=/mnt/c/Users/chris/dev/trading-data/trading.db

# TLS — set by podman-compose.dev.yml via the ../certs volume mount; only needed if running outside Docker
SSL_CERTFILE=
SSL_KEYFILE=
